#!/usr/bin/env bash

# Updates local Homebrew tap formula.

set -euo pipefail

#
# config
#

repo="gurgeous/2fer"
tap="${TWOFER_HOMEBREW_TAP:-../homebrew-tap}"
formula="${tap}/twofer.rb"
formula_name="$(basename "$formula")"
version="$(cargo pkgid | sed 's/.*[@#]//')"
tmp="tmp/homebrew-update"
assets=("2fer_${version}_darwin_amd64.tar.gz" "2fer_${version}_darwin_arm64.tar.gz" "2fer_${version}_linux_amd64.tar.gz")

#
# helpers
#

banner() {
  printf "\e[1;38;5;231;48;2;64;160;43m[%s] %-72s\e[0m\n" "$(date '+%H:%M:%S')" "$1"
}
warning() {
  printf "\e[1;38;5;231;48;2;251;100;11m[%s] %-72s\e[0m\n" "$(date '+%H:%M:%S')" "$1"
}
fatal() {
  printf "\e[1;38;5;231;48;2;210;15;57m[%s] %-72s\e[0m\n" "$(date '+%H:%M:%S')" "$1"
  exit 1
}
escape_regex() {
  printf '%s' "$1" | sed -e 's/[][\/.^$*+?{}()|]/\\&/g'
}
replace() {
  local label="$1"
  local pattern="$2"
  local replacement="$3"

  rg -q "$pattern" "$formula" || fatal "missing formula pattern: $label"
  PATTERN="$pattern" REPLACEMENT="$replacement" perl -0pi -e 's{$ENV{PATTERN}}{$ENV{REPLACEMENT}}g' "$formula"
}
replace_sha() {
  local asset="$1"
  local hash="$2"
  local anchor

  anchor="$(escape_regex "$asset")"
  rg -q "$anchor" "$formula" || fatal "missing formula asset: $asset"
  awk -v asset="$asset" '
    index($0, asset) { getline; if ($0 ~ /sha256 "[^"]+"/) found = 1 }
    END { exit found ? 0 : 1 }
  ' "$formula" || fatal "missing sha256 after: $asset"
  ASSET="$asset" HASH="$hash" perl -0pi -e '
    my $asset = quotemeta($ENV{ASSET});
    my $hash = $ENV{HASH};
    s{($asset[^\n]*\n\s*sha256 ")[^"]+(")}{$1$hash$2}s
      or die "missing sha256 after $ENV{ASSET}\n";
  ' "$formula"
}
sha256() {
  if command -v sha256sum >/dev/null; then
    sha256sum "$1" | cut -d' ' -f1
  elif command -v shasum >/dev/null; then
    shasum -a 256 "$1" | cut -d' ' -f1
  else
    fatal "missing sha256sum or shasum"
  fi
}

#
# sanity
#

[ -d "$tap/.git" ] || fatal "missing tap repo: $tap"
[ -f "$formula" ] || fatal "missing formula: $formula"
command -v gh >/dev/null || fatal "missing gh"
command -v rg >/dev/null || fatal "missing rg"

#
# fetch and validate release archives
#

banner "fetch release v${version}..."
rm -rf "$tmp" && mkdir -p "$tmp"

for asset in "${assets[@]}"; do
  archive="${tmp}/${asset}"

  banner "fetch ${asset}..."
  gh release download "v${version}" --repo "$repo" --pattern "$asset" --dir "$tmp" --clobber

  banner "validate ${asset}..."
  tar tzf "$archive" >"${archive}.files"
  rg -q "/2fer$" "${archive}.files" || fatal "archive missing 2fer binary: $asset"
  rg -q "/extra/2fer\\.bash$" "${archive}.files" || fatal "archive missing bash completion: $asset"
  rg -q "/extra/_2fer$" "${archive}.files" || fatal "archive missing zsh completion: $asset"
done

#
# update formula
#

banner "update formula..."
replace "version" 'version "[0-9.]+"' "version \"${version}\""
replace "release url" '/releases/download/v[0-9.]+/' "/releases/download/v${version}/"
replace "darwin amd64 asset" '2fer_[0-9.]+_darwin_amd64\.tar\.gz' "2fer_${version}_darwin_amd64.tar.gz"
replace "darwin arm64 asset" '2fer_[0-9.]+_darwin_arm64\.tar\.gz' "2fer_${version}_darwin_arm64.tar.gz"
replace "linux amd64 asset" '2fer_[0-9.]+_linux_amd64\.tar\.gz' "2fer_${version}_linux_amd64.tar.gz"
for asset in "${assets[@]}"; do
  hash="$(sha256 "${tmp}/${asset}")"
  replace_sha "$asset" "$hash"
done

#
# next steps
#

warning "tap updated but not committed"
echo
echo "Next steps:"
echo "  cd $tap"
echo "  git diff"
echo "  git commit -am ${version} && git push"
